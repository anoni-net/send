# Kept out of the build context.
#
# Two things that look excludable and are not:
#
#   .git    build/version_plugin.js reads the commit through git-rev-sync to
#           fill /__version__. Excluding it does not fail the build, it just
#           silently reports commit "unknown".
#   test/   webpack.config.js calls require.resolve('./test/frontend/index.js')
#           at module scope rather than behind the FRONTEND_TESTS check, so the
#           config fails to load without it.
.nyc_output
.github
assets_src
coverage
docs
node_modules
.vscode
.DS_Store
# A local .env holds secrets and never belongs in the build context. It only
# reaches the builder stage today (the final stage copies named paths), so
# nothing leaks into the published image, but keeping it out removes the
# foot-gun entirely. .gitignore already excludes it from the repo.
.env
